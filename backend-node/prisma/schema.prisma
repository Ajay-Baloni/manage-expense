generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum TransactionType {
  income
  expense
}

enum CategoryType {
  income
  expense
  both
}

enum BudgetPeriod {
  weekly
  monthly
}

enum AlertLevel {
  warning
  exceeded
}

enum RecurringFrequency {
  daily
  weekly
  monthly
  yearly
}

enum SplitType {
  equal
  exact
  percentage
  shares
}

enum ImportStatus {
  pending
  processing
  completed
  failed
}

enum Theme {
  light
  dark
  system
}

// ---------------------------------------------------------------------------
// Accounts
// ---------------------------------------------------------------------------

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  firstName    String    @default("")
  lastName     String    @default("")
  isActive     Boolean   @default(true)
  isStaff      Boolean   @default(false)
  dateJoined   DateTime  @default(now())

  profile          UserProfile?
  resetTokens      PasswordResetToken[]
  categories       Category[]
  budgets          Budget[]
  tags             Tag[]
  transactions     Transaction[]
  recurringRules   RecurringRule[]
  createdGroups    SplitGroup[]         @relation("GroupCreator")
  memberships      SplitGroupMember[]
  paidExpenses     SplitExpense[]       @relation("ExpensePaidByUser")
  importJobs       ImportJob[]

  @@index([email])
}

model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarUrl String   @default("")
  currency  String   @default("INR")
  timezone  String   @default("UTC")
  theme     Theme    @default(system)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique @default(uuid())
  createdAt DateTime @default(now())
  expiresAt DateTime
  isUsed    Boolean  @default(false)

  @@index([token])
}

// ---------------------------------------------------------------------------
// Categories & budgets
// ---------------------------------------------------------------------------

model Category {
  id        String       @id @default(cuid())
  userId    String? // null => system default category
  user      User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  icon      String       @default("tag")
  color     String       @default("#6366f1")
  type      CategoryType @default(both)
  isDefault Boolean      @default(false)
  createdAt DateTime     @default(now())

  budgets        Budget[]
  transactions   Transaction[]
  recurringRules RecurringRule[]

  @@index([userId])
  @@index([type])
}

model Budget {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId     String
  category       Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  period         BudgetPeriod @default(monthly)
  // Anchor date (first day of the month the budget was created). Budgets are
  // recurring: spend is always evaluated over the current period.
  month          DateTime
  limitAmount    Decimal      @db.Decimal(12, 2)
  alertThreshold Int          @default(80)

  alerts BudgetAlert[]

  @@unique([userId, categoryId, period])
  @@index([userId, period])
}

model BudgetAlert {
  id             String     @id @default(cuid())
  budgetId       String
  budget         Budget     @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  triggeredAt    DateTime   @default(now())
  percentageUsed Decimal    @db.Decimal(6, 2)
  periodStart    DateTime?
  level          AlertLevel @default(warning)

  @@index([budgetId, periodStart, level])
}

// ---------------------------------------------------------------------------
// Transactions
// ---------------------------------------------------------------------------

model Tag {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  color        String        @default("#6366f1")
  transactions Transaction[] @relation("TransactionTags")

  @@unique([userId, name])
  @@index([userId])
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  categoryId  String?
  category    Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  date        DateTime        @db.Date
  description String
  tags        Tag[]           @relation("TransactionTags")
  receiptUrl  String          @default("")
  notes       String          @default("")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([userId, date])
  @@index([userId, type])
  @@index([userId, categoryId])
  @@index([date])
}

model RecurringRule {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        TransactionType
  amount      Decimal            @db.Decimal(12, 2)
  categoryId  String?
  category    Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  description String
  frequency   RecurringFrequency
  startDate   DateTime           @db.Date
  nextRun     DateTime           @db.Date
  endDate     DateTime?          @db.Date
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())

  @@index([userId, isActive])
  @@index([nextRun])
}

// ---------------------------------------------------------------------------
// Splits
// ---------------------------------------------------------------------------

model SplitGroup {
  id          String             @id @default(cuid())
  name        String
  createdById String
  createdBy   User               @relation("GroupCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime           @default(now())

  members     SplitGroupMember[]
  expenses    SplitExpense[]
  settlements SplitSettlement[]

  @@index([createdById])
}

model GuestUser {
  id           String             @id @default(cuid())
  name         String
  email        String             @default("")
  memberships  SplitGroupMember[]
  paidExpenses SplitExpense[]     @relation("ExpensePaidByGuest")
}

model SplitGroupMember {
  id          String      @id @default(cuid())
  groupId     String
  group       SplitGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestUserId String?
  guestUser   GuestUser?  @relation(fields: [guestUserId], references: [id], onDelete: Cascade)
  joinedAt    DateTime    @default(now())

  shares             SplitExpenseShare[]
  settlementsPaid    SplitSettlement[]   @relation("SettlementPayer")
  settlementsRecv    SplitSettlement[]   @relation("SettlementReceiver")

  @@index([groupId])
}

model SplitExpense {
  id           String     @id @default(cuid())
  groupId      String
  group        SplitGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidByUserId String?
  paidByUser   User?      @relation("ExpensePaidByUser", fields: [paidByUserId], references: [id], onDelete: SetNull)
  paidByGuestId String?
  paidByGuest  GuestUser? @relation("ExpensePaidByGuest", fields: [paidByGuestId], references: [id], onDelete: SetNull)
  amount       Decimal    @db.Decimal(12, 2)
  description  String
  date         DateTime   @db.Date
  splitType    SplitType  @default(equal)
  createdAt    DateTime   @default(now())

  shares SplitExpenseShare[]

  @@index([groupId, date])
}

model SplitExpenseShare {
  id          String           @id @default(cuid())
  expenseId   String
  expense     SplitExpense     @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  memberId    String
  member      SplitGroupMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  shareAmount Decimal          @db.Decimal(12, 2)
  isSettled   Boolean          @default(false)

  @@index([expenseId, memberId])
}

model SplitSettlement {
  id               String           @id @default(cuid())
  groupId          String
  group            SplitGroup       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payerMemberId    String
  payerMember      SplitGroupMember @relation("SettlementPayer", fields: [payerMemberId], references: [id], onDelete: Cascade)
  receiverMemberId String
  receiverMember   SplitGroupMember @relation("SettlementReceiver", fields: [receiverMemberId], references: [id], onDelete: Cascade)
  amount           Decimal          @db.Decimal(12, 2)
  settledAt        DateTime         @default(now())
  note             String           @default("")

  @@index([groupId])
}

// ---------------------------------------------------------------------------
// Reports
// ---------------------------------------------------------------------------

model ImportJob {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName     String
  status       ImportStatus @default(pending)
  totalRows    Int          @default(0)
  importedRows Int          @default(0)
  errorsJson   Json         @default("[]")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([userId, createdAt])
}
